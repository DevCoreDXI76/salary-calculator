# 배포 URL (끝에 / 없이). Vercel 배포 후 실제 URL로 교체
VITE_SITE_URL=https://salaryfit.coredxi.com

# Google Analytics 4 Measurement ID (G-XXXXXXXX). 없으면 Analytics 미로드
# 실제 값은 로컬 .env + Vercel Environment Variables에 설정
VITE_GA_MEASUREMENT_ID=

# 문의 이메일 (개인정보 처리방침·푸터)
VITE_CONTACT_EMAIL=devcoredxi00@coredxi.com

# Google AdSense 클라이언트 ID (ca-pub-XXXXXXXX). 승인 후 설정. 없으면 광고 플레이스홀더
VITE_ADSENSE_CLIENT=

# AdSense 유닛 slot ID (승인 후, 선택)
# VITE_ADSENSE_SLOT_TOP=
# VITE_ADSENSE_SLOT_BOTTOM=
# VITE_ADSENSE_SLOT_SIDEBAR=
# VITE_ADSENSE_SLOT_FEED=
